# Firebase Config (loaded from file path)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# SlipOK API Credentials for payment verification
SLIPOK_API_URL=https://api.slipok.com/api/line/apikey/YOUR_ENDPOINT_ID
SLIPOK_API_KEY=YOUR_SLIPOK_API_KEY

# Allowed receiver account for validation
# This should be the bank account number that receives the funds
ALLOWED_RECEIVER_ACCOUNT=YOUR_BANK_ACCOUNT_NUMBER
ALLOWED_RECEIVER_NAME=YOUR_BANK_ACCOUNT_NAME
